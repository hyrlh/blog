$block-caption
  text-decoration: none
  text-transform: uppercase
  letter-spacing: 2px
  color: color-grey
  margin-bottom: 1em
  margin-left: 5px
  line-height: 1em
  text-shadow: 0 1px #fff
  font-weight: bold

$block
  background: #fff
  box-shadow: 1px 2px 3px #ddd
  border: 1px solid color-border
  border-radius: 3px

$base-style
  h1
    font-size: 2em
  h2
    font-size: 1.5em
  h3
    font-size: 1.3em
  h4
    font-size: 1.2em
  h5
    font-size: 1em
  h6
    font-size: 1em
    color: color-grey
  hr
    border: 1px dashed color-border
  strong
    font-weight: bold
  em, cite
    font-style: italic
  sup, sub
    font-size: 0.75em
    line-height: 0
    position: relative
    vertical-align: baseline
  sup
    top: -0.5em
  sub
    bottom: -0.2em
  small
    font-size: 0.85em
  acronym, abbr
    border-bottom: 1px dotted
  ul, ol, dl
    margin: 0 20px
    line-height: line-height
  ul, ol
    ul, ol
      margin-top: 0
      margin-bottom: 0
  ul
    list-style: disc
  ol
    list-style: decimal
  dt
    font-weight: bold

#comments
  margin-top: 2rem

.site-update-banner
  position: fixed
  right: 20px
  bottom: 20px
  z-index: 1200
  display: flex
  align-items: center
  gap: 0.8rem
  padding: 0.85rem 1rem
  background: rgba(36, 54, 77, 0.96)
  color: #fff
  border-radius: 12px
  box-shadow: 0 12px 30px rgba(15, 23, 42, 0.25)

.site-update-banner__text
  font-size: 0.92rem
  line-height: 1.4

.site-update-banner__button
  border: none
  border-radius: 999px
  padding: 0.45rem 0.85rem
  background: #fff
  color: #24364d
  font-size: 0.88rem
  font-weight: 600
  cursor: pointer
  &:hover
    background: #eaf1f8

.docs-shell
  display: flex
  gap: 1.5rem
  margin-top: block-margin
  margin-bottom: 3rem
  max-width: 1440px
  @media mq-tablet
    display: block
  @media mq-mobile
    display: block

#main.docs-content
  flex: 1
  width: auto
  max-width: none
  float: none

.docs-nav
  width: 280px
  flex: 0 0 280px
  min-width: 0

.docs-nav-panel
  @extend $block
  padding: 1.25rem 1rem
  position: sticky
  top: 20px
  max-height: calc(100vh - 40px)
  overflow: auto

.docs-tree-root
  list-style: none
  margin: 0
  padding: 0

.docs-tree-dir
  margin-top: 0.85rem
  &:first-child
    margin-top: 0

.docs-tree-dir details
  display: block

.docs-tree-dir summary
  list-style: none
  display: flex
  align-items: center
  justify-content: space-between
  gap: 0.6rem
  padding: 0.8rem 0.9rem
  border-radius: 10px
  background: #edf3fb
  cursor: pointer
  &::-webkit-details-marker
    display: none
  &:hover
    background: #e6eef8
  .docs-tree-dir-label
    color: #24364d
    font-size: 1.08rem
    font-weight: 700
    flex: 1
  span
    color: #6c8199
    font-size: 0.8rem
    font-weight: 600

.docs-tree-children
  list-style: none
  margin: 0.45rem 0 0
  padding: 0

.docs-tree-post
  margin: 0.4rem 0 0
  a
    display: block
    padding: 0.7rem 0.9rem
    border-radius: 10px
    background: #fff
    color: #4b5c72
    text-decoration: none
    line-height: 1.5
    font-size: 0.92rem
    font-weight: 500
    &:hover
      background: #f7fafc
      color: color-link
  &.is-current a
    background: #e0f2fe
    color: #0369a1
    font-weight: 600

.docs-tree-level-1 > a,
.docs-tree-level-1 > details > summary
  margin-left: 0.55rem

.docs-tree-level-2 > a,
.docs-tree-level-2 > details > summary
  margin-left: 1rem

.docs-tree-level-3 > a,
.docs-tree-level-3 > details > summary
  margin-left: 1.45rem

.docs-tree-level-4 > a,
.docs-tree-level-4 > details > summary
  margin-left: 1.9rem

.docs-overview-panel
  @extend $block
  padding: 1.4rem 1.5rem
  margin-bottom: 1rem

.docs-overview-kicker
  margin: 0 0 0.7rem
  font-size: 0.8rem
  letter-spacing: 0.14em
  text-transform: uppercase
  color: #6b7c93

.docs-overview-title
  margin: 0
  font-size: 2rem
  color: #1f2937

.docs-overview-summary
  margin: 0.9rem 0 0
  color: #5b6778
  line-height: 1.8

.docs-overview-heading
  margin: 0
  font-size: 1.1rem
  color: #1f2937

.docs-overview-text
  margin: 0.8rem 0 0
  color: #5b6778
  line-height: 1.8

.docs-overview-links
  margin-top: 1rem
  display: flex
  flex-wrap: wrap
  gap: 0.8rem
  a
    display: inline-block
    padding: 0.65rem 0.95rem
    background: #f4f7fb
    border-radius: 999px
    text-decoration: none
    color: #334155
    &:hover
      color: color-link
      background: #eaf1f8

.docs-category-head
  display: flex
  justify-content: space-between
  align-items: center
  gap: 1rem
  margin-bottom: 0.8rem

.docs-category-title
  margin: 0
  font-size: 1.25rem
  a
    color: #1f2937
    text-decoration: none
    &:hover
      color: color-link

.docs-category-count
  color: #94a3b8
  font-size: 0.85rem

.docs-category-post-list
  list-style: none
  margin: 0
  padding: 0
  li
    display: flex
    justify-content: space-between
    gap: 1rem
    align-items: baseline
    padding: 0.75rem 0
    border-top: 1px solid #eef2f7
    &:first-child
      border-top: none
  a
    color: #334155
    text-decoration: none
    line-height: 1.6
    &:hover
      color: color-link
  time
    color: #94a3b8
    white-space: nowrap
    font-size: 0.84rem

.docs-empty
  margin: 0
  color: #64748b
