<%
function hasCurrentPost(node, currentPath) {
  if (node.posts.some(function(post){ return post.path === currentPath; })) {
    return true;
  }

  return node.dirs.some(function(child){
    return hasCurrentPost(child, currentPath);
  });
}

function renderDir(node, currentPath, level) {
  var opened = hasCurrentPost(node, currentPath);
%>
  <li class="docs-tree-dir docs-tree-level-<%= level %>">
    <details<%= opened ? ' open' : '' %>>
      <summary>
        <span class="docs-tree-dir-label"><%= node.displayName %></span>
        <span><%= node.dirs.length + node.posts.length %></span>
      </summary>
      <ul class="docs-tree-children">
        <% node.dirs.forEach(function(child){ %>
          <%- renderDir(child, currentPath, level + 1) %>
        <% }) %>
        <% node.posts.forEach(function(post){ %>
          <% var isCurrentPost = currentPath === post.path; %>
          <li class="docs-tree-post docs-tree-level-<%= level + 1 %><%= isCurrentPost ? ' is-current' : '' %>">
            <a href="<%- url_for(post.path) %>"><%= post.title %></a>
          </li>
        <% }) %>
      </ul>
    </details>
  </li>
<% } %>

<% var docsTree = build_docs_tree(site.posts); %>

<aside class="docs-nav">
  <div class="widget-wrap docs-nav-wrap">
    <h3 class="widget-title">目录</h3>
    <div class="widget docs-nav-panel">
    <nav class="docs-tree">
      <ul class="docs-tree-root">
        <% docsTree.dirs.forEach(function(dir){ %>
          <%- renderDir(dir, page.path, 0) %>
        <% }) %>
        <% docsTree.posts.forEach(function(post){ %>
          <% var isCurrentPost = page.path === post.path; %>
          <li class="docs-tree-post docs-tree-level-0<%= isCurrentPost ? ' is-current' : '' %>">
            <a href="<%- url_for(post.path) %>"><%= post.title %></a>
          </li>
        <% }) %>
      </ul>
    </nav>
    </div>
  </div>
</aside>
